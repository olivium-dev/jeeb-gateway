{
  "title": "Jeeb Gateway — API Latency (T-backend-050)",
  "uid": "jeeb-gateway-api-latency",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["jeeb-gateway", "latency", "slo"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "route",
        "type": "query",
        "label": "Route",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(jeeb_gateway_http_request_duration_seconds_bucket, route)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "current": { "selected": false, "text": "All", "value": "$__all" }
      },
      {
        "name": "method",
        "type": "query",
        "label": "Method",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(jeeb_gateway_http_request_duration_seconds_bucket, method)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "current": { "selected": false, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "p50 — request duration by route",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le, route) (rate(jeeb_gateway_http_request_duration_seconds_bucket{route=~\"$route\", method=~\"$method\"}[5m])))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p95 — request duration by route (SLO line at 400ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.4 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(jeeb_gateway_http_request_duration_seconds_bucket{route=~\"$route\", method=~\"$method\"}[5m])))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p99 — request duration by route",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le, route) (rate(jeeb_gateway_http_request_duration_seconds_bucket{route=~\"$route\", method=~\"$method\"}[5m])))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Per-endpoint quantile summary (last 5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": { "unit": "s", "decimals": 3 }
      },
      "targets": [
        {
          "refId": "p50",
          "expr": "histogram_quantile(0.50, sum by (le, method, route) (rate(jeeb_gateway_http_request_duration_seconds_bucket{route=~\"$route\", method=~\"$method\"}[5m])))",
          "legendFormat": "{{method}} {{route}}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "p95",
          "expr": "histogram_quantile(0.95, sum by (le, method, route) (rate(jeeb_gateway_http_request_duration_seconds_bucket{route=~\"$route\", method=~\"$method\"}[5m])))",
          "legendFormat": "{{method}} {{route}}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "p99",
          "expr": "histogram_quantile(0.99, sum by (le, method, route) (rate(jeeb_gateway_http_request_duration_seconds_bucket{route=~\"$route\", method=~\"$method\"}[5m])))",
          "legendFormat": "{{method}} {{route}}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requests per second by status_class",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 34 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "stacking": { "mode": "normal" } }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status_class) (rate(jeeb_gateway_http_request_duration_seconds_count{route=~\"$route\", method=~\"$method\"}[1m]))",
          "legendFormat": "{{status_class}}"
        }
      ]
    }
  ]
}
