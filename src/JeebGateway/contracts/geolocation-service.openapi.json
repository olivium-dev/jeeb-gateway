    "/v1/geo/agents/online": {
      "get": {
        "description": "Return every Agent currently flagged online.\n\nThe fast-path for matching: a covering index on `(available, last_seen_at)`\nkeeps this query O(online-count).",
        "operationId": "list_online_agents_v1_geo_agents_online_get",
