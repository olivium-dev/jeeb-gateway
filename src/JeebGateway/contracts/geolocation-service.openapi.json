    "/v1/geo/agents/online/nearby": {
      "get": {
        "description": "Return the online, fresh, in-radius Agents nearest the query point.\n\nThe durable presence row (K3) carries each Agent's latest position +\ngeohash5 + role, so this runs a single indexed spatial query with no\njoin to the track-scoped ping table. A `available=True` Agent with\na stale or missing fix is excluded.",
        "operationId": "list_nearby_online_agents_v1_geo_agents_online_nearby_get",
        "parameters": [
          {
            "description": "Query point latitude.",
            "in": "query",
            "name": "latitude",
            "required": true,
            "schema": {
              "description": "Query point latitude.",
              "maximum": 90,
              "minimum": -90,
              "title": "Latitude",
              "type": "number"
            }
          },
          {
            "description": "Query point longitude.",
            "in": "query",
            "name": "longitude",
            "required": true,
            "schema": {
              "description": "Query point longitude.",
              "maximum": 180,
              "minimum": -180,
              "title": "Longitude",
              "type": "number"
            }
          },
          {
            "description": "Tier radius in metres (e.g. 1000 / 3000 / 8000 per F6).",
            "in": "query",
            "name": "radius_m",
            "required": true,
            "schema": {
              "description": "Tier radius in metres (e.g. 1000 / 3000 / 8000 per F6).",
              "exclusiveMinimum": 0,
              "maximum": 200000,
              "title": "Radius M",
              "type": "number"
            }
          },
          {
            "description": "Exclude Agents whose last fix is older than this.",
            "in": "query",
            "name": "max_staleness_seconds",
            "required": false,
            "schema": {
              "default": 120.0,
              "description": "Exclude Agents whose last fix is older than this.",
              "exclusiveMinimum": 0,
              "maximum": 86400,
              "title": "Max Staleness Seconds",
              "type": "number"
            }
          },
          {
            "description": "Presence role to scope to; pass empty/omit-as-null for any.",
            "in": "query",
            "name": "role",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": "agent",
              "description": "Presence role to scope to; pass empty/omit-as-null for any.",
              "title": "Role"
            }
          },
          {
            "description": "Max candidates returned.",
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 100,
              "description": "Max candidates returned.",
              "maximum": 500,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/NearbyAgentResponse"
                  },
                  "title": "Response List Nearby Online Agents V1 Geo Agents Online Nearby Get",
                  "type": "array"
                }
              }
            },
            "description": "Online, fresh Agents within `radius_m` of (latitude, longitude), nearest-first. Consumed by the matching engine (C4 / S06) to scope `POST /matching/run` candidates via a PostGIS `ST_DWithin` query."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List online Agents within a radius (tier-radius matching)",
        "tags": [
          "agents"
        ]
      }
    },
