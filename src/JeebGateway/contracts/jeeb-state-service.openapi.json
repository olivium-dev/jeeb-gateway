    "/v1/state/idempotency": {
      "put": {
        "tags": [
          "State"
        ],
        "summary": "Insert-or-return an idempotency key (ON CONFLICT DO NOTHING). 201=created, 200=replay returns original.",
        "operationId": "UpsertIdempotencyKey",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IdempotencyPutRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/v1/state/idempotency/{key}": {
      "get": {
        "tags": [
          "State"
        ],
        "operationId": "GetIdempotencyKey",
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IdempotencyRecord"
                }
              }
            }
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
