<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>JeebGateway</RootNamespace>
    <AssemblyName>JeebGateway</AssemblyName>
    <!--
      CS0618 — legacy controllers under Controllers/ are intentionally marked
      [Obsolete] to flag them for the BFF migration follow-ups. Suppress the
      warning at the project level so the IDE still shows the strikethrough
      but the build stays green. Tracked in GATEWAY-REMEDIATION-PLAN.md.
    -->
    <NoWarn>$(NoWarn);CS0618</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="JeebGateway.IntegrationTests" />
  </ItemGroup>

  <ItemGroup>
    <!-- Pinned OpenAPI specs in src/JeebGateway/contracts/ are part of the build artifact. -->
    <None Include="contracts\**\*.json" CopyToOutputDirectory="Never" />
    <!-- regenerate-clients.sh is reference material; not copied. -->
    <None Include="scripts\**\*.sh" CopyToOutputDirectory="Never" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="8.0.11" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.9.0" />
    <!--
      Newtonsoft.Json — required by the NSwag-generated salehly client
      Services/Generated/ServiceRemoteUserPreferencesClient.cs (jsonLibrary:Newtonsoft).
      salehly-gateway carries this dependency; the exact-mirror clients use it for
      (de)serialization. Pinned to 13.0.3 to match the generator's declared
      Newtonsoft.Json v13.0.0.0 contract.
    -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="OpenTelemetry.Extensions.Hosting" Version="1.9.0" />
    <PackageReference Include="OpenTelemetry.Instrumentation.AspNetCore" Version="1.9.0" />
    <PackageReference Include="OpenTelemetry.Instrumentation.Http" Version="1.9.0" />
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" Version="1.9.0" />
    <PackageReference Include="OpenTelemetry.Exporter.Prometheus.AspNetCore" Version="1.9.0-beta.2" />
    <PackageReference Include="Microsoft.Extensions.Diagnostics.HealthChecks" Version="8.0.11" />
    <PackageReference Include="System.IdentityModel.Tokens.Jwt" Version="8.1.2" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="8.0.11" />
    <!--
      BFF resilience pipeline (Polly v8 via the official Microsoft.Extensions.* wrapper).
      Provides .AddResilienceHandler() used by Extensions/ServiceClientExtensions.cs.
    -->
    <PackageReference Include="Microsoft.Extensions.Http.Resilience" Version="8.10.0" />
    <!--
      URL-group health checks for downstream services in Extensions/HealthCheckExtensions.cs.
    -->
    <PackageReference Include="AspNetCore.HealthChecks.Uris" Version="8.0.1" />

    <!--
      Redis-backed chat topology map (RedisChatTopologyMap). Holds the
      channel<->conversation id-map (userId->memberId, sortedPair->channel/sessions)
      that the gateway must resolve on every chat send/history because the GENERIC
      chat-service exposes no lookup-by-external-id. In-memory was lost on restart
      and not multi-replica safe; Redis (native 192.168.2.50:6379, real value only
      in appsettings.Production.json) makes it durable + shared. The InMemory
      fallback is selected when Redis:ConnectionString is absent (dev/test).
    -->
    <PackageReference Include="StackExchange.Redis" Version="2.8.16" />

    <!--
      T-BE-001 / JEB-471 — OTP sign-in path.
      libphonenumber-csharp normalises +961 / 00961 / 0079... → canonical E.164
      and surfaces the RegionCode used by AC-PhoneNorm to reject non-LB phones.
      Phone hashing uses HMAC-SHA256 from System.Security.Cryptography with a
      server-side pepper (JeebJwt:PhonePepper). PR #32 review B1 — the prior
      bcrypt-on-phone implementation generated a random salt per call so the
      phone.hash tag could not correlate; HMAC-SHA256 restores determinism.
    -->
    <PackageReference Include="libphonenumber-csharp" Version="8.13.51" />
  </ItemGroup>

</Project>
