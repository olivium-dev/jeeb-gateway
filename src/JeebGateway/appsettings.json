{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Otel": {
    "Endpoint": "http://localhost:4317"
  },
  "FeatureFlags": {
    "DurableRequests": {
      "_comment": "SPINE-FOUNDATION / ADR-006. Default false = today's green in-memory create path (S05 H3 -> 201, S01-S04 unchanged). Flip to true ONLY after state-service saga_bundles + delivery POST /api/v1/deliveries are deployed and smoke-passed, staging-first, via FeatureFlags__DurableRequests__Enabled=true.",
      "Enabled": false,
      "SagaTag": "delivery_saga_v1",
      "TenantId": "default"
    },
    "UseUpstream": {
      "Auth": false,
      "Delivery": false,
      "Matching": false,
      "Geolocation": false,
      "Notification": false,
      "Push": false,
      "RemoteUserPreferences": false,
      "Offer": false,
      "Ban": false,
      "Cdn": false,
      "Voice": false,
      "Otp": false,
      "Realtime": false,
      "ContractSigning": false,
      "FormBuilder": false,
      "Kyc": false
    },
    "Heartbeat": {
      "_comment": "S06 / ADR-HB-001 — presence cutover to the NEW reusable heart-beat service. Default OFF: the availability surface keeps using the delivery-service presence wire. Flip via FeatureFlags__Heartbeat__Enabled=true once heart-beat is live. roleKey is the OPAQUE consumer namespace heart-beat stores but never interprets.",
      "Enabled": false,
      "RoleKey": "jeeber"
    }
  },
  "Features": {
    "_comment": "DevEndpoints gates the additive /dev/* test-harness routes (DevController). MUST stay false in every committed appsettings; the routes return 404 when off. Flip on ONLY via env var Features__DevEndpoints__Enabled=true in the seeding-harness environment. The gateway never auto-seeds.",
    "DevEndpoints": {
      "Enabled": false
    },
    "_comment_swagger": "Swagger gates the admin-role-gated /swagger* OpenAPI surface (Program.cs). MUST stay false in every committed appsettings; /swagger* returns 404 when off. Flip on ONLY via env var Features__Swagger__Enabled=true (deploy-to-jeeb.yml swagger_ui input). When ON it is admin-role-gated (non-admin => 404) — NEVER the open Dev/Testing branch. jeeb.fds-1.com is PUBLIC.",
    "Swagger": {
      "Enabled": false
    }
  },
  "Auth": {
    "_comment": "Auth:Otp configures the production phone sign-in OTP orchestration (AuthOtpController, /v1/auth/otp/*). ApplicationId is the Jeeb tenant's application id in the shared one-time-password service, forwarded on every SendOTP/ValidateOTP (the service keys Phone rows by application id). Set per env; the committed default is an empty placeholder. ttlSeconds is the contract constant the gateway surfaces on request (the service does not return a TTL).",
    "Otp": {
      "ApplicationId": "",
      "TtlSeconds": 300
    }
  },
  "ServiceAuth": {
    "Caller": "jeeb-gateway",
    "Enabled": false
  },
  "Services": {
    "Auth": "http://localhost:5001",
    "Delivery": "http://localhost:5002",
    "Matching": {
      "BaseUrl": "http://localhost:5003"
    },
    "Geolocation": "http://localhost:5004",
    "ServiceOTP": {
      "BaseUrl": "http://localhost:5005"
    },
    "Realtime": {
      "BaseUrl": "http://192.168.2.50:10069/"
    },
    "ContractSigning": {
      "BaseUrl": "http://192.168.2.50:10071/"
    },
    "Cdn": {
      "BaseUrl": "http://192.168.2.50:10072/"
    },
    "FormBuilder": {
      "BaseUrl": "http://192.168.2.50:10070/"
    },
    "Kyc": {
      "_comment": "kyc-service (S03/ADR-0004) is NOT yet deployed — repo+DB owner/SSH ESCALATED. PLACEHOLDER BaseUrl; FeatureFlags:UseUpstream:Kyc stays false until the service ships (suggested host port 10074).",
      "BaseUrl": "http://192.168.2.50:PORT_TBD/"
    },
    "HeartBeat": {
      "_comment": "heart-beat (S06 / ADR-HB-001) — NEW reusable presence service (Go + Redis). NOT YET DEPLOYED: PLACEHOLDER BaseUrl (port UNVERIFIED — confirm against the live fleet port map before creating the swarm service). FeatureFlags:Heartbeat:Enabled stays false until the service ships and is smoke-passed.",
      "BaseUrl": "http://192.168.2.50:PORT_TBD/"
    }
  },
  "RemoteUserPreferencesServiceApi": {
    "BaseUrl": "http://localhost:5006"
  },
  "FeedbackServiceApi": {
    "BaseUrl": "http://localhost:5011"
  },
  "CatalogServiceApi": {
    "BaseUrl": "http://localhost:5012"
  },
  "UserManagementServiceApi": {
    "BaseUrl": "http://localhost:5013"
  },
  "Jwt": {
    "Issuer": "jeeb-gateway",
    "Audience": "jeeb-clients",
    "SigningKey": "REPLACE-WITH-PRODUCTION-SIGNING-KEY-32+",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "UmJwt": {
    "Issuer": "user-management",
    "Audience": "user-management",
    "SigningKey": ""
  },
  "GatewayRateLimit": {
    "PerPhonePerMin": 3,
    "PerIpPerMin": 10
