          "MaxLatitude": 31.97,
          "MinLongitude": 35.92,
          "MaxLongitude": 35.95
        },
        {
          "Key": "amman-abdoun",
          "Name": "Amman — Abdoun",
          "MinLatitude": 31.93,
          "MaxLatitude": 31.96,
          "MinLongitude": 35.86,
          "MaxLongitude": 35.90
        },
        {
          "Key": "amman-shmeisani",
          "Name": "Amman — Shmeisani",
          "MinLatitude": 31.96,
          "MaxLatitude": 31.99,
          "MinLongitude": 35.89,
          "MaxLongitude": 35.92
        }
      ]
    }
  },
  "Push": {
    "DeliverySla": "00:00:05",
    "RetryDelay": "00:00:30",
    "RetryQueueScanInterval": "00:00:01",
    "TransportTimeout": "00:00:02",
    "FcmProjectId": "REPLACE-WITH-FCM-PROJECT-ID",
    "FcmBearerToken": "REPLACE-WITH-FCM-BEARER-TOKEN",
    "UseFcmTransport": false
  },
  "Whisper": {
    "BaseUrl": "https://api.openai.com/v1",
    "Model": "whisper-1",
    "Language": "ar",
    "FakeTranscribe": true,
    "Timeout": "00:00:10",
    "MaxAttempts": 3,
    "InitialBackoff": "00:00:00.500",
    "MaxBackoff": "00:00:08",
    "CircuitBreakerFailureThreshold": 5,
    "CircuitBreakerOpenDuration": "00:00:30"
  }
}
