{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Otel": {
    "Endpoint": "http://localhost:4317"
  },
  "Jwt": {
    "Issuer": "jeeb-gateway",
    "Audience": "jeeb-clients",
    "SigningKey": "REPLACE-WITH-PRODUCTION-SIGNING-KEY-32+",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "Security": {
    "Cors": {
      "PolicyName": "JeebAdminPanel",
      "AllowedOrigins": [
        "http://localhost:5173",
        "http://localhost:3000",
        "https://admin.jeeb.local"
      ],
      "AllowedMethods": [ "GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS" ],
      "AllowedHeaders": [ "Authorization", "Content-Type", "X-Correlation-Id", "X-User-Id", "X-User-Roles" ],
      "ExposedHeaders": [ "X-Correlation-Id", "Retry-After", "X-RateLimit-Limit", "X-RateLimit-Remaining" ],
      "AllowCredentials": true,
      "PreflightMaxAgeSeconds": 600
    },
    "RateLimit": {
      "Enabled": true,
      "UserPermitsPerMinute": 100,
      "IpPermitsPerMinute": 1000,
      "WindowSegments": 6
    },
    "Headers": {
      "Enabled": true,
      "HstsMaxAgeSeconds": 31536000,
      "HstsIncludeSubdomains": true,
      "HstsPreload": true,
      "ContentSecurityPolicy": "default-src 'none'; frame-ancestors 'none'"
    }
  },
  "Admin": {
    "Zones": {
      "RefreshInterval": "00:00:30",
      "Boundaries": [
        {
          "Key": "amman-downtown",
          "Name": "Amman — Downtown",
          "MinLatitude": 31.94,
          "MaxLatitude": 31.97,
          "MinLongitude": 35.92,
          "MaxLongitude": 35.95
        },
        {
          "Key": "amman-abdoun",
          "Name": "Amman — Abdoun",
          "MinLatitude": 31.93,
          "MaxLatitude": 31.96,
          "MinLongitude": 35.86,
          "MaxLongitude": 35.90
        },
        {
          "Key": "amman-shmeisani",
          "Name": "Amman — Shmeisani",
          "MinLatitude": 31.96,
          "MaxLatitude": 31.99,
          "MinLongitude": 35.89,
          "MaxLongitude": 35.92
        }
      ]
    }
  },
  "Whisper": {
    "BaseUrl": "https://api.openai.com/v1",
    "Model": "whisper-1",
    "Language": "ar",
    "Timeout": "00:00:10",
    "MaxAttempts": 3,
    "InitialBackoff": "00:00:00.500",
    "MaxBackoff": "00:00:08",
    "CircuitBreakerFailureThreshold": 5,
    "CircuitBreakerOpenDuration": "00:00:30"
  }
}
