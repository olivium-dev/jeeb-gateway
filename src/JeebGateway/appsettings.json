  },
  "ChatServiceApi": {
    "BaseUrl": "http://localhost:5007"
  },
  "ServiceNotificationClient": {
    "BaseUrl": "http://localhost:5009"
  },
  "PushNotificationServiceApi": {
    "BaseUrl": "http://localhost:5010"
  },
  "Security": {
    "Cors": {
      "PolicyName": "JeebAdminPanel",
      "AllowedOrigins": [
        "http://localhost:5173",
        "http://localhost:3000",
        "https://admin.jeeb.local"
      ],
      "AllowedMethods": [ "GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS" ],
      "AllowedHeaders": [ "Authorization", "Content-Type", "X-Correlation-Id", "X-User-Id", "X-User-Roles", "X-Api-Key" ],
      "ExposedHeaders": [ "X-Correlation-Id", "Retry-After", "X-RateLimit-Limit", "X-RateLimit-Remaining" ],
      "AllowCredentials": true,
      "PreflightMaxAgeSeconds": 600
    },
    "RateLimit": {
      "Enabled": true,
      "UserPermitsPerMinute": 100,
      "IpPermitsPerMinute": 1000,
      "WindowSegments": 6,
      "AuthTokenBucketLimit": 20,
      "AuthTokensPerPeriod": 10,
      "AuthReplenishmentSeconds": 60,
      "SensitiveEndpointPermitsPerWindow": 30,
      "SensitiveEndpointWindowSeconds": 60
    },
    "Headers": {
      "Enabled": true,
      "HstsMaxAgeSeconds": 31536000,
      "HstsIncludeSubdomains": true,
      "HstsPreload": true,
      "ContentSecurityPolicy": "default-src 'none'; frame-ancestors 'none'"
    },
    "ApiKey": {
      "Enabled": false,
      "HeaderName": "X-Api-Key",
      "ServiceKeys": {}
    },
    "RequestValidation": {
      "Enabled": true,
      "MaxBodySizeBytes": 1048576,
      "MaxUrlLength": 2048,
      "MaxHeaderValueLength": 8192,
      "AllowedContentTypes": [ "application/json", "multipart/form-data", "application/x-www-form-urlencoded" ]
    }
  },
  "Admin": {
    "Zones": {
      "RefreshInterval": "00:00:30",
      "Boundaries": [
